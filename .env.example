# Set exactly ONE of the following:
ANTHROPIC_API_KEY=your-anthropic-key-here
# GEMINI_API_KEY=your-gemini-key-here
# OPENROUTER_API_KEY=your-openrouter-key-here

# Required for the REST API (api/main.py) — clients must send this value
# in the X-API-Key header.
API_KEY=your-shared-secret-here

# Origin allowed to call the API from a browser (the frontend's dev server
# by default). Only needed if the frontend runs somewhere other than
# http://localhost:5173.
# FRONTEND_ORIGIN=http://localhost:5173
